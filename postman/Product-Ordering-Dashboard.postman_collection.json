{
  "info": {
    "name": "Product Ordering Dashboard API",
    "description": "Full REST API for the MERN Product Ordering Dashboard. Set the `baseUrl` and `token` collection variables before hitting protected endpoints. The `Register` and `Login` requests include test scripts that capture the returned token into the `token` variable automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "mockupId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) pm.collectionVariables.set('token', data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Rivera\",\n  \"email\": \"designer@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"designer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) pm.collectionVariables.set('token', data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"designer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Current user (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Mockups",
      "item": [
        {
          "name": "List mockups",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/mockups", "host": ["{{baseUrl}}"], "path": ["api", "mockups"] }
          }
        },
        {
          "name": "Get mockup by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/mockups/{{mockupId}}", "host": ["{{baseUrl}}"], "path": ["api", "mockups", "{{mockupId}}"] }
          }
        },
        {
          "name": "Create mockup (designer, multipart)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.mockup) pm.collectionVariables.set('mockupId', data.mockup._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/mockups", "host": ["{{baseUrl}}"], "path": ["api", "mockups"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Eco-Box Series V2", "type": "text" },
                { "key": "description", "value": "Sustainable packaging box mockup.", "type": "text" },
                { "key": "price", "value": "49", "type": "text" },
                { "key": "category", "value": "Packaging", "type": "text" },
                { "key": "image", "type": "file", "src": [] }
              ]
            },
            "description": "Attach an image file under the `image` form field. Only designers may hit this endpoint."
          }
        },
        {
          "name": "Update mockup",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/mockups/{{mockupId}}", "host": ["{{baseUrl}}"], "path": ["api", "mockups", "{{mockupId}}"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Eco-Box Series V3", "type": "text" },
                { "key": "price", "value": "55", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Delete mockup",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/mockups/{{mockupId}}", "host": ["{{baseUrl}}"], "path": ["api", "mockups", "{{mockupId}}"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Designer stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/stats", "host": ["{{baseUrl}}"], "path": ["api", "orders", "stats"] }
          }
        },
        {
          "name": "Create order (client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.order) pm.collectionVariables.set('orderId', data.order._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mockupId\": \"{{mockupId}}\",\n  \"quantity\": 3,\n  \"notes\": \"Please gloss-laminate the final run.\"\n}"
            }
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}"] }
          }
        },
        {
          "name": "Update status (designer)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_production\"\n}"
            }
          }
        },
        {
          "name": "Cancel order (client)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
      }
    }
  ]
}
